# ===========================================
# PureFind — Environment Variables
# ===========================================
# Copy this to .env.local and fill in your values

# --- Google AI (FREE tier) ---
# Get your free API key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# --- Supabase ---
# Anon key is for public reads. Service role key is used by the PA-API
# cache and analytics logger — KEEP IT SERVER-SIDE ONLY.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Amazon Associates ---
# Sign up at: https://affiliate-program.amazon.com
# This tag is used as the click-through tracking ID when a PartnerTag isn't
# otherwise set via AMAZON_PAAPI_PARTNER_TAG.
NEXT_PUBLIC_AMAZON_TAG=purefind-20

# --- Amazon Product Advertising API 5.0 (REQUIRED — replaces scraping) ---
# Get credentials at: https://affiliate-program.amazon.com/assoc_credentials/home
# Step-by-step: docs/amazon-paapi-setup.md
# Requires ≥3 qualifying sales in the last 180 days to unlock the credentials page.
AMAZON_PAAPI_ACCESS_KEY=your_paapi_access_key_here
AMAZON_PAAPI_SECRET_KEY=your_paapi_secret_key_here
AMAZON_PAAPI_PARTNER_TAG=purefind-20
AMAZON_PAAPI_HOST=webservices.amazon.com
AMAZON_PAAPI_REGION=us-east-1

# Break-glass ONLY. Setting this to "1" reactivates the deprecated HTML scraper
# in amazon-lookup.legacy.ts. This violates Amazon's Operating Agreement §5
# and risks an Associates ban. Do NOT set in production.
# AMAZON_ALLOW_SCRAPE=0

# --- Site Config ---
NEXT_PUBLIC_SITE_NAME=PureFind
NEXT_PUBLIC_SITE_URL=https://purefind.com
