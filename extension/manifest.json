{
  "manifest_version": 3,
  "name": "PureFind — AI Product Search",
  "version": "1.0.0",
  "description": "PureFind's AI instantly finds the best product for your needs with honest pros, cons, and links.",
  "permissions": [
    "storage",
    "action"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://purefind.vercel.app/*"
  ],
  "action": {
    "default_title": "PureFind AI Search",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.js",
        "icons/*"
      ],
      "matches": [
        "https://www.amazon.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}